# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Source code
*.c text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.inc text eol=lf

# Build/config
*.cmake text eol=lf
*.in text eol=lf
*.py text eol=lf
*.sh text eol=lf
CMakeLists.txt text eol=lf
Kconfig text eol=lf
Kconfig.projbuild text eol=lf
sdkconfig.defaults text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Data
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.csv text eol=lf

# Binary files (no conversion)
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pdf binary
*.bin binary
*.elf binary
*.hex binary
