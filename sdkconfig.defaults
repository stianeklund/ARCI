# Enable USB CDC support via TinyUSB
CONFIG_TINYUSB_CDC_ENABLED=y
CONFIG_TINYUSB_CDC_COUNT=2
# Increase CDC ring buffers for higher throughput and fewer wakeups
CONFIG_TINYUSB_CDC_RX_BUFSIZE=256
CONFIG_TINYUSB_CDC_TX_BUFSIZE=256
# Use Espressif VID but custom descriptors for other settings
CONFIG_TINYUSB_DESC_USE_ESPRESSIF_VID=y
CONFIG_TINYUSB_DESC_USE_DEFAULT_PID=n
# Custom PID to match our working configuration
CONFIG_TINYUSB_DESC_CUSTOM_PID=0x4001
# Custom device version and strings to match our descriptors
CONFIG_TINYUSB_DESC_BCD_DEVICE=0x0100
CONFIG_TINYUSB_DESC_MANUFACTURER_STRING="Stian Eklund"
CONFIG_TINYUSB_DESC_PRODUCT_STRING="ARCI"
CONFIG_TINYUSB_DESC_SERIAL_STRING="001"
CONFIG_TINYUSB_DESC_CDC_STRING="ARCI CAT Interface"

# WiFi Hostname Configuration
CONFIG_WIFI_HOSTNAME="arci"

# Log level settings
CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# Main task stack size - increased for unit tests with RadioManager
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192

# Enable FreeRTOS runtime statistics for CPU usage monitoring
CONFIG_FREERTOS_GENERATE_RUN_TIME_STATS=y
CONFIG_FREERTOS_USE_TRACE_FACILITY=y
CONFIG_FREERTOS_USE_STATS_FORMATTING_FUNCTIONS=y

# --- Encoder Handler defaults (digit-anchored acceleration) ---
CONFIG_ENCODER_USE_PCNT=y
CONFIG_ENCODER_PCNT_GLITCH_US=6
CONFIG_ENCODER_ACCEL_ENABLE=y
CONFIG_ENCODER_BAND1_RPS_X100=30
CONFIG_ENCODER_BAND2_RPS_X100=120
CONFIG_ENCODER_BAND_HYSTERESIS_PERCENT=20
CONFIG_ENCODER_LIVE_UPDATE_INTERVAL_MS=15
CONFIG_ENCODER_FINAL_UPDATE_DELAY_MS=50
CONFIG_ENCODER_MIN_STEPS_THRESHOLD=1
